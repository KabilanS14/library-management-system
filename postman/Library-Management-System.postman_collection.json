{
  "info": {
    "name": "Library Management System API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {"key": "baseUrl", "value": "http://localhost:8080"},
    {"key": "jwtToken", "value": ""}
  ],
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"name\": \"John\",\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\"\n}"},
            "url": {"raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth", "register"]}
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"email\": \"admin@library.com\",\n  \"password\": \"Admin@123\"\n}"},
            "url": {"raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"]}
          }
        }
      ]
    },
    {
      "name": "Books",
      "item": [
        {
          "name": "Create Book",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{jwtToken}}"}
            ],
            "body": {"mode": "raw", "raw": "{\n  \"title\": \"Spring Boot in Action\",\n  \"author\": \"Craig Walls\",\n  \"isbn\": \"9781617292545\",\n  \"category\": \"Programming\",\n  \"publisher\": \"Manning\",\n  \"publishedYear\": 2023,\n  \"language\": \"English\",\n  \"totalCopies\": 5\n}"},
            "url": {"raw": "{{baseUrl}}/books", "host": ["{{baseUrl}}"], "path": ["books"]}
          }
        },
        {
          "name": "Get All Books",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{jwtToken}}"}],
            "url": {"raw": "{{baseUrl}}/books", "host": ["{{baseUrl}}"], "path": ["books"]}
          }
        },
        {
          "name": "Search Books",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{jwtToken}}"}],
            "url": {"raw": "{{baseUrl}}/books/search?keyword=spring", "host": ["{{baseUrl}}"], "path": ["books", "search"], "query": [{"key": "keyword", "value": "spring"}]}
          }
        }
      ]
    },
    {
      "name": "Borrow",
      "item": [
        {
          "name": "Borrow Book",
          "request": {
            "method": "POST",
            "header": [{"key": "Authorization", "value": "Bearer {{jwtToken}}"}],
            "url": {"raw": "{{baseUrl}}/borrow/1", "host": ["{{baseUrl}}"], "path": ["borrow", "1"]}
          }
        },
        {
          "name": "Return Book",
          "request": {
            "method": "POST",
            "header": [{"key": "Authorization", "value": "Bearer {{jwtToken}}"}],
            "url": {"raw": "{{baseUrl}}/return/1", "host": ["{{baseUrl}}"], "path": ["return", "1"]}
          }
        },
        {
          "name": "Borrow History",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{jwtToken}}"}],
            "url": {"raw": "{{baseUrl}}/borrow/history", "host": ["{{baseUrl}}"], "path": ["borrow", "history"]}
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "All Borrow Records",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{jwtToken}}"}],
            "url": {"raw": "{{baseUrl}}/admin/borrow-records", "host": ["{{baseUrl}}"], "path": ["admin", "borrow-records"]}
          }
        },
        {
          "name": "Overdue Books",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{jwtToken}}"}],
            "url": {"raw": "{{baseUrl}}/admin/borrow-records/overdue", "host": ["{{baseUrl}}"], "path": ["admin", "borrow-records", "overdue"]}
          }
        },
        {
          "name": "Pending Fines",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{jwtToken}}"}],
            "url": {"raw": "{{baseUrl}}/admin/borrow-records/fines", "host": ["{{baseUrl}}"], "path": ["admin", "borrow-records", "fines"]}
          }
        }
      ]
    }
  ]
}
